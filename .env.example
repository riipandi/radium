# App Configuration
RADIUM_APP_MODE=development
RADIUM_APP_SECRET_KEY=_PUT_SECURE_ENCRYPTION_KEY_FOR_APP_HERE_
RADIUM_JWT_SECRET_KEY=_PUT_SECURE_ENCRYPTION_KEY_FOR_JWT_HERE_
RADIUM_JWT_ACCESS_TOKEN_EXPIRY=900
RADIUM_JWT_REFRESH_TOKEN_EXPIRY=7200
RADIUM_SESSION_STORAGE=database

# Logging Configuration
RADIUM_LOG_LEVEL=info
RADIUM_LOG_SHOW_TIMESTAMP=true
RADIUM_LOG_ROTATION=daily
RADIUM_LOG_SHOW_MODULE=true
RADIUM_LOG_REQUEST_SAMPLING=100
RADIUM_LOG_SLOW_REQUESTS_ONLY=false
RADIUM_LOG_SLOW_THRESHOLD_MS=1000
RADIUM_LOG_ANALYTICS_MODE=full

# CORS Configuration
RADIUM_CORS_ENABLED=true
RADIUM_CORS_ALLOW_ORIGINS=*
RADIUM_CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,HEAD,OPTIONS,PATCH
RADIUM_CORS_ALLOW_HEADERS=accept,accept-language,authorization,content-type,user-agent,x-requested-id
RADIUM_CORS_ALLOW_CREDENTIALS=false
RADIUM_CORS_MAX_AGE=3600

# Database Configuration
RADIUM_DATABASE_AUTO_MIGRATE=true
RADIUM_DATABASE_URL=
RADIUM_DATABASE_TOKEN=

# Mailer Configuration
MAILER_FROM_EMAIL=mailer@example.com
MAILER_FROM_NAME="Radium Admin"
MAILER_SMTP_HOST=localhost
MAILER_SMTP_PORT=1025
MAILER_SMTP_USERNAME=maileruser1
MAILER_SMTP_PASSWORD=mailerpass1
MAILER_SMTP_SECURE=false

# Storage Configuration
STORAGE_S3_ACCESS_KEY_ID=s3admin
STORAGE_S3_SECRET_ACCESS_KEY=s3passw0rd
STORAGE_S3_BUCKET_DEFAULT=devbucket
STORAGE_S3_FORCE_PATH_STYLE=true
STORAGE_S3_PATH_PREFIX=
STORAGE_S3_ENDPOINT_URL=http://localhost:9100
STORAGE_S3_PUBLIC_URL=http://localhost:9180
STORAGE_S3_REGION=auto
STORAGE_S3_SIGNED_URL_EXPIRES=3600
STORAGE_MAX_UPLOAD_SIZE=5242880

# Provider Configuration - OpenAI
PROVIDER_OPENAI_API_KEY=sk-your-openai-api-key-here
PROVIDER_OPENAI_BASE_URL=

# Provider Configuration - Anthropic
PROVIDER_ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
PROVIDER_ANTHROPIC_BASE_URL=

# Provider Configuration - AWS Bedrock
PROVIDER_BEDROCK_API_KEY=your-bedrock-api-key
PROVIDER_BEDROCK_ACCESS_KEY=your-aws-access-key
PROVIDER_BEDROCK_BASE_URL=

# Provider Configuration - Cohere
PROVIDER_COHERE_API_KEY=your-cohere-api-key
PROVIDER_COHERE_BASE_URL=

# Provider Configuration - Azure OpenAI
PROVIDER_AZURE_OPENAI_API_KEY=your-azure-openai-api-key
PROVIDER_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Provider Configuration - Google Vertex AI
PROVIDER_VERTEX_PROJECT_ID=your-gcp-project-id
PROVIDER_VERTEX_CREDENTIALS=/path/to/service-account.json
PROVIDER_VERTEX_BASE_URL=
